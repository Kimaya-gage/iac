provider "aws" {
  # access_key and secret_key removed. 
  # Authentication should rely on environment variables, shared credential files, 
  # IAM roles, or AWS CLI profiles for enhanced security.
  region = "us-east-1"
}

# --- VPC and Networking Setup (Required for secure EC2 and RDS) ---
resource "aws_vpc" "main" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "secure-app-vpc"
  }
}

resource "aws_internet_gateway" "gw" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name = "secure-app-igw"
  }
}

resource "aws_subnet" "public" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.1.0/24"
  availability_zone = "us-east-1a"

  tags = {
    Name = "secure-app-public-subnet"
  }
}

resource "aws_subnet" "private" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.0.2.0/24"
  availability_zone = "us-east-1a"

  tags = {
    Name = "secure-app-private-subnet"
  }
}

resource "aws_eip" "nat_eip" {
  domain = "vpc"
  tags = {
    Name = "secure-app-nat-eip"
  }
}

resource "aws_nat_gateway" "nat" {
  allocation_id = aws_eip.nat_eip.id
  subnet_id     = aws_subnet.public.id

  tags = {
    Name = "secure-app-nat-gw"
  }
  depends_on = [aws_internet_gateway.gw]
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }

  tags = {
    Name = "secure-app-public-rt"
  }
}

resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table" "private" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.nat.id
  }

  tags = {
    Name = "secure-app-private-rt"
  }
}

resource "aws_route_table_association" "private" {
  subnet_id      = aws_subnet.private.id
  route_table_id = aws_route_table.private.id
}

# --- Secure S3 Bucket ---
# ✅ S3 Bucket: Not public, encrypted, versioned
resource "aws_s3_bucket" "secure_bucket" {
  bucket = "my-secure-application-bucket"

  tags = {
    Name        = "MySecureAppBucket"
    Environment = "Production"
  }
}

# Enforce all public access blocks
resource "aws_s3_bucket_public_access_block" "secure_bucket_public_access_block" {
  bucket = aws_s3_bucket.secure_bucket.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Enforce server-side encryption with S3-managed keys (SSE-S3)
resource "aws_s3_bucket_server_side_encryption_configuration" "secure_bucket_sse" {
  bucket = aws_s3_bucket.secure_bucket.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# Enable versioning for data recovery and audit
resource "aws_s3_bucket_versioning" "secure_bucket_versioning" {
  bucket = aws_s3_bucket.secure_bucket.id
  configuration {
    status = "Enabled"
  }
}

# Set object ownership to BucketOwnerEnforced to disable ACLs
resource "aws_s3_bucket_ownership_controls" "secure_bucket_ownership_controls" {
  bucket = aws_s3_bucket.secure_bucket.id
  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

# --- Secure S3 Logging Bucket ---
resource "aws_s3_bucket" "log_bucket" {
  bucket = "my-secure-application-log-bucket"

  tags = {
    Name        = "MySecureAppLogBucket"
    Environment = "Production"
    Purpose     = "AccessLogs"
  }
}

resource "aws_s3_bucket_public_access_block" "log_bucket_public_access_block" {
  bucket = aws_s3_bucket.log_bucket.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_acl" "log_bucket_acl" {
  depends_on = [aws_s3_bucket_public_access_block.log_bucket_public_access_block]
  bucket     = aws_s3_bucket.log_bucket.id
  acl        = "log-delivery-write"
}

resource "aws_s3_bucket_server_side_encryption_configuration" "log_bucket_sse" {
  bucket = aws_s3_bucket.log_bucket.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# ✅ S3 Logging: Enabled and targets a secure logging bucket
resource "aws_s3_bucket_logging" "secure_bucket_logging" {
  bucket        = aws_s3_bucket.secure_bucket.id
  target_bucket = aws_s3_bucket.log_bucket.id
  target_prefix = "log/"
}

# --- Security Groups ---
# ✅ Security Group for EC2: Least privilege ingress/egress
resource "aws_security_group" "ec2_sg" {
  name        = "secure_ec2_sg"
  description = "Allow SSH from specific IP and restricted egress"
  vpc_id      = aws_vpc.main.id

  # Ingress: Allow SSH from a specific, trusted IP range (replace with your IP or a bastion host SG)
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # REMINDER: Replace with your actual trusted IP range (e.g., your_office_ip/32)!
  }

  # Egress: Allow outbound for common services like DNS, HTTP/HTTPS for updates/patches
  egress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  egress {
    from_port   = 53
    to_port     = 53
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  egress {
    from_port   = 53
    to_port     = 53
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "secure_ec2_sg"
  }
}

# ✅ Security Group for RDS: Allow DB traffic only from EC2 SG, no public access
resource "aws_security_group" "rds_sg" {
  name        = "secure_rds_sg"
  description = "Allow DB access only from EC2 security group"
  vpc_id      = aws_vpc.main.id

  # Ingress: Allow MySQL/Aurora port from the EC2 security group only
  ingress {
    from_port       = 3306
    to_port         = 3306
    protocol        = "tcp"
    security_groups = [aws_security_group.ec2_sg.id]
  }

  # No explicit egress needed, AWS default allows all outbound which is often acceptable for databases 
  # or could be further restricted if necessary.

  tags = {
    Name = "secure_rds_sg"
  }
}

# --- IAM Role and Instance Profile for EC2 ---
# ✅ IAM Role for EC2: Least privilege (e.g., S3 Read-Only)
resource "aws_iam_role" "ec2_role" {
  name               = "secure_ec2_role"
  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action    = "sts:AssumeRole"
        Effect    = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Name = "secure_ec2_role"
  }
}

resource "aws_iam_role_policy_attachment" "s3_read_only" {
  role       = aws_iam_role.ec2_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess" # Example: Read-only access to S3
}

resource "aws_iam_instance_profile" "ec2_profile" {
  name = "secure_ec2_profile"
  role = aws_iam_role.ec2_role.name
}

# --- EC2 Instance ---
# ✅ EC2 Instance: With tags, dedicated SG, IAM instance profile, in private subnet
resource "aws_instance" "secure_instance" {
  ami                    = "ami-0b0af3577d29bc489" # Example: Amazon Linux 2 AMI for us-east-1
  instance_type          = "t2.micro"
  subnet_id              = aws_subnet.private.id
  vpc_security_group_ids = [aws_security_group.ec2_sg.id]
  iam_instance_profile   = aws_iam_instance_profile.ec2_profile.name

  # Tags for identification and management
  tags = {
    Name        = "MySecureAppInstance"
    Environment = "Production"
    Project     = "SecureApp"
    Owner       = "DevOpsTeam"
  }
}

# --- EBS Volume ---
# ✅ EBS Volume: Encrypted
resource "aws_ebs_volume" "secure_volume" {
  availability_zone = "us-east-1a"
  size              = 8
  encrypted         = true # Data at rest encryption enabled

  # Optionally, specify a KMS key for custom encryption:
  # kms_key_id = aws_kms_key.ebs_kms_key.arn

  tags = {
    Name        = "MySecureEBSVolume"
    Environment = "Production"
  }
}

resource "aws_volume_attachment" "ebs_att" {
  device_name = "/dev/sdh"
  volume_id   = aws_ebs_volume.secure_volume.id
  instance_id = aws_instance.secure_instance.id
}

# --- IAM Policy ---
# ✅ IAM Policy: Adheres to least privilege principle
resource "aws_iam_policy" "secure_policy" {
  name        = "secure_s3_read_policy"
  description = "Allows read-only access to the application S3 bucket"

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Effect   = "Allow",
        Action   = [
          "s3:GetObject",
          "s3:ListBucket",
          "s3:GetBucketLocation"
        ],
        Resource = [
          aws_s3_bucket.secure_bucket.arn,
          "${aws_s3_bucket.secure_bucket.arn}/*"
        ]
      }
    ]
  })
}

# --- RDS Instance ---
# ✅ RDS Subnet Group (required for private RDS deployment)
resource "aws_db_subnet_group" "secure_db_subnet_group" {
  name       = "secure-db-subnet-group"
  subnet_ids = [aws_subnet.private.id]

  tags = {
    Name = "SecureDBSubnetGroup"
  }
}

# ✅ RDS Instance: Not publicly accessible, strong credentials, in private subnet, dedicated SG
resource "aws_db_instance" "secure_db" {
  allocated_storage   = 20
  engine              = "mysql"
  engine_version      = "8.0.32" # Specify a secure engine version
  instance_class      = "db.t2.micro"
  publicly_accessible = false # Critical: Not exposed to the internet
  db_subnet_group_name = aws_db_subnet_group.secure_db_subnet_group.name
  vpc_security_group_ids = [aws_security_group.rds_sg.id]

  username = "app_user" # Use a specific username, not 'admin'
  password = random_password.db_password_generated.result # Use a securely generated password

  skip_final_snapshot = true # For demo purposes, consider 'false' for production
  storage_encrypted   = true # Encrypt data at rest for RDS
  multi_az            = false # For demo, set to true for production high availability

  tags = {
    Name        = "MySecureRDSInstance"
    Environment = "Production"
  }
}

# ✅ Generated strong password for RDS (integrating with previous vulnerability)
resource "random_password" "db_password_generated" {
  length           = 16
  special          = true
  override_special = "_-.!@#$%^&*()"
  min_upper        = 1
  min_lower        = 1
  min_numeric      = 1
}

# --- Variables ---
# ✅ Variable: Sensitive, no hardcoded default
variable "db_password_external" {
  description = "The database password. Should be provided securely (e.g., via TF_VAR_db_password_external, .tfvars file, or fetched from a secret manager)."
  type        = string
  sensitive   = true # Mark as sensitive to hide from logs and UI where possible
  # default = "supersecret123" # Removed hardcoded default
}

# Note: The 'db_password_external' variable is kept to demonstrate its correct declaration
# but is not directly used in the 'aws_db_instance' resource above, 
# which now uses 'random_password' for better security automation.
# If you need to supply a pre-existing password, you would use 'db_password_external' there.
