provider "aws" {
  region = "us-east-1"
}

# --- Data Source to find the latest Amazon Linux 2 AMI ---
# This ensures you're using a recent, patched operating system image.
data "aws_ami" "amazon_linux_2" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# --- Create an SSH Key Pair for secure administrative access ---
# The private key generated here should be stored securely and never exposed.
resource "tls_private_key" "myec2_key" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "myec2_key" {
  key_name   = "myec2-key-${var.environment}"
  public_key = tls_private_key.myec2_key.public_key_openssh
}

# --- Data Source to reference the default VPC ---
# Needed to associate security groups if a custom VPC is not defined.
data "aws_vpc" "default" {
  default = true
}

# --- Define a Security Group for the EC2 instance with least privilege ---
# This controls network access to and from the instance.
resource "aws_security_group" "myec2_sg" {
  name        = "myec2-security-group-${var.environment}"
  description = "Security group for my EC2 instance with restricted access"
  vpc_id      = data.aws_vpc.default.id

  # Ingress rule: Allow SSH access (port 22) from a specific IP range.
  # CRITICAL: Replace "YOUR_MANAGEMENT_IP_CIDR" with your actual public IP CIDR (e.g., "X.X.X.X/32").
  # Allowing "0.0.0.0/0" for SSH is highly discouraged for production environments.
  # Consider using AWS Systems Manager Session Manager for SSH-less access to avoid opening port 22 entirely.
  ingress {
    description = "SSH from trusted network"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["YOUR_MANAGEMENT_IP_CIDR"] # Placeholder for security. Update this!
  }

  # If this instance is meant to be a web server, uncomment and configure HTTP/HTTPS rules:
  /*
  ingress {
    description = "HTTP access from internet"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  ingress {
    description = "HTTPS access from internet"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  */

  # Egress rule: Allow all outbound traffic.
  # Restrict this further if your application has specific outbound requirements.
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # Represents all protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "myec2-security-group-${var.environment}"
  }
}

# --- EC2 Instance definition ---
resource "aws_instance" "myec2" {
  ami           = data.aws_ami.amazon_linux_2.id        # Use the latest secure AMI
  instance_type = "t2.micro"                            # Instance type as specified
  key_name      = aws_key_pair.myec2_key.key_name       # Associate the SSH key pair
  vpc_security_group_ids = [aws_security_group.myec2_sg.id] # Associate the restrictive security group
  
  # Explicitly control public IP assignment.
  # Set to 'true' if the instance needs a public IP (e.g., web server).
  # Set to 'false' for instances in private subnets or that only need private IP.
  associate_public_ip_address = true # Set to false if not needed, use private subnet for better security

  tags = {
    Name = "my-ec2-instance-${var.environment}" # Fix syntax: string in quotes, add uniqueness
  }
}

# --- Outputs ---
# CRITICAL: The private key should be stored securely, not output directly in production.
# Marking as sensitive prevents it from being displayed in Terraform output.
output "generated_private_key_pem" {
  value       = tls_private_key.myec2_key.private_key_pem
  sensitive   = true
  description = "The generated private key for SSH access. Store securely and do not expose."
}

output "instance_public_ip" {
  value       = aws_instance.myec2.public_ip # Fix typo: public_ippp -> public_ip
  description = "The public IP address of the EC2 instance."
}

output "instance_private_ip" {
  value       = aws_instance.myec2.private_ip
  description = "The private IP address of the EC2 instance."
}

output "public_key_openssh" {
  value       = tls_private_key.myec2_key.public_key_openssh
  description = "The generated public key in OpenSSH format."
}

# --- Variables ---
variable "environment" {
  description = "Deployment environment (e.g., dev, prod) for resource naming."
  type        = string
  default     = "dev"
}
