resource "aws_s3_bucket" "secure_bucket" {
  bucket = "my-secure-bucket-123"

  # Ensure the bucket is private by default
  acl = "private"

  # Enable versioning to protect against accidental deletions and overwrites
  versioning {
    enabled = true
  }

  # Enforce server-side encryption for all objects at rest (using S3-managed keys by default)
  server_side_encryption_configuration {
    rule {
      apply_server_side_encryption_by_default {
        sse_algorithm = "AES256"
      }
    }
  }

  # Optional: Add tags for better resource management and cost allocation
  tags = {
    Environment = "Production"
    Project     = "SecureStorage"
  }
}

resource "aws_s3_bucket_public_access_block" "secure_block" {
  bucket = aws_s3_bucket.secure_bucket.id

  # Crucially, all public access blocking mechanisms must be enabled
  # block_public_acls: Block new public ACLs and updating any existing ones to be public
  block_public_acls = true
  # block_public_policy: Block new public bucket policies and updating any existing ones to be public
  block_public_policy = true
  # ignore_public_acls: Ignore all public ACLs (granting access only through bucket policies, if allowed)
  ignore_public_acls = true
  # restrict_public_buckets: Restrict public bucket policies for buckets that also have public ACLs
  restrict_public_buckets = true
}