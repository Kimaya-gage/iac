provider "aws" {
  region = "us-east-1"
}

# Data source to fetch the default VPC, needed for security group creation
data "aws_vpc" "default" {
  default = true
}

# --- FIX: Create an explicit Security Group with restricted rules ---
resource "aws_security_group" "myec2_sg" {
  name        = "myec2-security-group"
  description = "Allow SSH inbound traffic and all outbound traffic for my EC2 instance"
  vpc_id      = data.aws_vpc.default.id

  # Allow SSH from anywhere. 
  # WARNING: In a production environment, restrict 'cidr_blocks' to known IP addresses only.
  ingress {
    description = "SSH from anywhere"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Allow all outbound traffic
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "myec2-security-group"
  }
}

# --- FIX: Create an IAM Role for the instance ---
resource "aws_iam_role" "myec2_role" {
  name = "myec2-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      },
    ]
  })

  tags = {
    Name = "myec2-role"
  }
}

# --- FIX: Attach necessary permissions to the IAM role (example: ReadOnlyAccess) ---
resource "aws_iam_role_policy_attachment" "myec2_role_attachment" {
  role       = aws_iam_role.myec2_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonEC2ReadOnlyAccess" # Replace with least-privilege policy for your application
}

# --- FIX: Create an IAM Instance Profile for the role ---
resource "aws_iam_instance_profile" "myec2_profile" {
  name = "myec2-instance-profile"
  role = aws_iam_role.myec2_role.name
}

resource "aws_instance" "myec2" {
  # FIX: Use a valid AMI for us-east-1 (Amazon Linux 2023 example)
  ami           = "ami-053b0d53c279acc90"
  instance_type = "t2.micro"

  # FIX: Correct tags syntax (missing quotes around value)
  tags = {
    Name = "my-ec2-instance"
  }

  # FIX: Associate with the newly created secure security group
  vpc_security_group_ids = [aws_security_group.myec2_sg.id]

  # FIX: Associate with the IAM Instance Profile for secure AWS service access
  iam_instance_profile = aws_iam_instance_profile.myec2_profile.name

  # FIX: Explicitly set public IP association if intended (as suggested by output block)
  # If a public IP is not intended, set to `false` and place in a private subnet.
  associate_public_ip_address = true
}

# --- FIX: Correct output attribute name ---
output "instance_ip" {
  value       = aws_instance.myec2.public_ip
  description = "The public IP address of the EC2 instance."
}
